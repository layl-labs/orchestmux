  "description": "Multi-agent orchestration for coding CLIs in tmux — spawn, dispatch, and wait on Claude Code, Codex, Kimi, OpenCode, and Gemini workers from one terminal.",
  "keywords": [
    "multi-agent",
    "orchestration",
    "tmux",
    "ai-agents",
    "coding-agent",
    "claude-code",
    "codex",
    "cli"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "orchestmux": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
